{
  "functions": {
    "source": "backend",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/bookings",
        "run": { "serviceId": "api", "region": "us-central1" }
      },
      {
        "source": "/bookings/**",
        "run": { "serviceId": "api", "region": "us-central1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
